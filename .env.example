# Application runtime
APP_ENV=development
APP_DEBUG=true

# Data source selection
# Supported values: local, snowflake
DATA_BACKEND=local

# Local data paths
RAW_DATA_DIR=data/raw/GiveMeSomeCredit
INTERIM_DATA_DIR=data/interim
PROCESSED_DATA_DIR=data/processed
TRAIN_FILE=cs-training.csv
TEST_FILE=cs-test.csv
DATA_DICTIONARY_FILE=Data Dictionary.xls

# Artifact and reporting paths
ARTIFACT_DIR=artifacts
MODEL_DIR=artifacts/models
REPORT_DIR=reports/figures
MODEL_NAME=xgboost_credit_risk
MODEL_VERSION=0.1.0

# Training and evaluation defaults
TARGET_COLUMN=SeriousDlqin2yrs
ID_COLUMN=Unnamed: 0
RANDOM_STATE=42
TEST_SIZE=0.2
CV_FOLDS=5
POSITIVE_CLASS_LABEL=1
DECISION_THRESHOLD=0.5

# Streamlit application
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Snowflake connection
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=ML_RISK_CONTROL
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=

# Snowflake logical schemas
SNOWFLAKE_RAW_SCHEMA=RAW
SNOWFLAKE_CURATED_SCHEMA=CURATED
SNOWFLAKE_FEATURES_SCHEMA=FEATURES
SNOWFLAKE_SERVING_SCHEMA=SERVING

# Optional writeback and monitoring controls
ENABLE_SNOWFLAKE_WRITEBACK=false
ENABLE_MONITORING_EXPORT=false
